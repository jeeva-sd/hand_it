{
    "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",

    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },

    "files": { "ignoreUnknown": false, "includes": ["src/**/*"] },

    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120,
        "bracketSpacing": true,
        "bracketSameLine": false,
        "attributePosition": "auto",
        "expand": "never"
    },

    "linter": {
        "enabled": true,

        "rules": {
            "style": { "useImportType": "off", "useConst": "error" },
            "recommended": true,
            "correctness": {
                "noConstAssign": "error",
                "noConstantCondition": "error",
                "noConstructorReturn": "error",
                "noEmptyPattern": "error",
                "noInvalidUseBeforeDeclaration": "error",
                "noMissingVarFunction": "error",
                "noPrecisionLoss": "error",
                "noPrivateImports": "error",
                "noProcessGlobal": "off",
                "noSelfAssign": "error",
                "noSetterReturn": "error",
                "noSwitchDeclarations": "error",
                "noUndeclaredDependencies": "error",
                "noUndeclaredVariables": "error",
                "noUnreachable": "error",
                "noUnreachableSuper": "error",
                "noUnsafeFinally": "error",
                "noUnsafeOptionalChaining": "error",
                "noVoidTypeReturn": "error",
                "noChildrenProp": "error",
                "noGlobalDirnameFilename": "error",
                "noGlobalObjectCalls": "error",
                "noInvalidBuiltinInstantiation": "error",
                "noInvalidConstructorSuper": "error",
                "noStringCaseMismatch": "error",
                "noUnusedFunctionParameters": "warn"
            },

            "suspicious": {
                "noDebugger": "warn",
                "noDuplicateCase": "error",
                "noDuplicateParameters": "error",
                "noDuplicateObjectKeys": "error",
                "noRedeclare": "error",
                "noShadowRestrictedNames": "error",
                "noVar": "error",
                "noWith": "error",
                "noDuplicateElseIf": "error",
                "noSelfCompare": "error",
                "noTemplateCurlyInString": "warn",
                "noMisleadingCharacterClass": "warn"
            },

            "complexity": {
                "noForEach": "warn",
                "noStaticOnlyClass": "warn",
                "noUselessConstructor": "warn",
                "noUselessContinue": "warn",
                "noUselessLabel": "warn",
                "noUselessRename": "warn",
                "noUselessSwitchCase": "warn",
                "useArrowFunction": "warn",
                "useIndexOf": "warn",
                "useOptionalChain": "warn",
                "useWhile": "warn",
                "noUselessEmptyExport": "warn",
                "noUselessFragments": "warn",
                "noUselessStringConcat": "warn",
                "noUselessThisAlias": "warn",
                "useSimplifiedLogicExpression": "warn"
            },

            "performance": { "noBarrelFile": "off", "noDelete": "warn", "noReExportAll": "error" },

            "security": {
                "noSecrets": { "level": "warn", "options": { "entropyThreshold": 55 } },
                "noGlobalEval": "error",
                "noDangerouslySetInnerHtml": "error",
                "noBlankTarget": "warn"
            }
        }
    },

    "javascript": {
        "parser": { "unsafeParameterDecoratorsEnabled": true },
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "none",
            "arrowParentheses": "asNeeded",
            "lineWidth": 120,
            "bracketSpacing": true,
            "bracketSameLine": false
        }
    },

    "json": { "formatter": { "enabled": true } }
}
