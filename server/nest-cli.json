{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "entryFile": "app/main",
    "compilerOptions": {
        "deleteOutDir": true,
        "assets": [
            {
                "include": "views/**/*",
                "outDir": "dist/"
            },
            {
                "include": "public/**/*",
                "outDir": "dist/"
            },
            {
                "include": "uploads",
                "outDir": "dist/"
            }
        ]
    }
}
