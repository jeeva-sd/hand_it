{
    "name": "handit-backend",
    "version": "4.0.0",
    "description": "HandIt backend API",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "prebuild": "npx prisma generate",
        "build": "nest build",
        "debug": "nest start --debug --watch",
        "predev": "cross-env NODE_ENV=development npx prisma generate",
        "dev": "cross-env NODE_ENV=development nest start --watch",
        "prod": "cross-env NODE_ENV=production node dist/app/main",
        "format": "biome format --write src/",
        "lint": "biome check --write --unsafe --no-errors-on-unmatched && biome format --write src/ && npx prisma format",
        "db:generate": "cross-env NODE_ENV=development sh -c \"npx prisma generate && node scripts/run-prisma.js migrate dev --create-only\"",
        "db:reset": "cross-env NODE_ENV=development node scripts/run-prisma.js migrate reset",
        "db:update": "cross-env NODE_ENV=development node scripts/run-prisma.js migrate dev",
        "db:prod": "cross-env NODE_ENV=production node scripts/run-prisma.js migrate deploy",
        "db:studio": "cross-env NODE_ENV=development node scripts/run-prisma.js studio",
        "db:seed": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/integrations/database/seed.ts",
        "db:seed:revert": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/integrations/database/seedTestData.ts revert"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1068.0",
        "@fastify/compress": "^8.3.0",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.1.0",
        "@fastify/csrf-protection": "^7.1.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/multipart": "^9.3.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/static": "^8.3.0",
        "@fastify/view": "^11.1.1",
        "@nestjs/common": "^11.1.9",
        "@nestjs/core": "^11.1.9",
        "@nestjs/jwt": "^11.0.1",
        "@nestjs/microservices": "^11.1.9",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-fastify": "^11.1.9",
        "@paralleldrive/cuid2": "^2.2.2",
        "@prisma/client": "^6.19.1",
        "@sendgrid/mail": "^8.1.6",
        "amqplib": "^0.10.9",
        "axios": "^1.13.2",
        "cross-env": "^10.1.0",
        "fastify": "^5.6.2",
        "handlebars": "^4.7.8",
        "lru-cache": "^11.2.4",
        "nestjs-cls": "^6.1.0",
        "nodemailer": "^8.0.10",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.1.2",
        "rxjs": "^7.8.2",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "zod": "^4.1.13"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.8",
        "@nestjs/cli": "^11.0.14",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.9",
        "@types/amqplib": "^0.10.8",
        "@types/jest": "^30.0.0",
        "@types/moment-timezone": "^0.5.30",
        "@types/node": "^24.10.1",
        "@types/nodemailer": "^8.0.0",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^6.0.3",
        "jest": "^30.2.0",
        "prisma": "^6.19.1",
        "source-map-support": "^0.5.21",
        "supertest": "^7.1.4",
        "ts-jest": "^29.4.5",
        "typescript": "^5.9.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
