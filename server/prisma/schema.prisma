generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ************************************** Common *****************************************************

enum AuthTokenType {
  PASSWORD_RESET
  ACCOUNT_SETUP
}

enum UserStatus {
  PENDING
  ACTIVE
  DELETED
}

enum WorkspacePlan {
  FREE
  PRO
  TEAM
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  DRAFT
  ARCHIVED
}

model User {
  id                   String            @id @default(cuid())
  fname                String            @db.VarChar(50)
  lname                String            @db.VarChar(50)
  email                String            @unique(map: "uk_user_email") @db.VarChar(255)
  passwordHash         String?           @db.VarChar(255)
  status               UserStatus?       @default(PENDING)
  lastUsedWorkspaceId  String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  authTokens           AuthToken[]
  createdWorkspaces    Workspace[]       @relation("workspace_creator")
  lastUsedWorkspace    Workspace?        @relation("workspace_last_used_by_users", fields: [lastUsedWorkspaceId], references: [id], onDelete: SetNull)
  workspaceMemberships WorkspaceMember[]
  projectFavorites     ProjectFavorite[]

  @@index([fname], map: "idx_user_fname")
  @@index([lname], map: "idx_user_lname")
  @@index([lastUsedWorkspaceId], map: "idx_user_last_used_workspace")
  @@map("users")
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  tokenHash String        @unique(map: "uk_auth_token_hash") @db.VarChar(128)
  type      AuthTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type], map: "idx_auth_token_user_type")
  @@index([expiresAt], map: "idx_auth_token_expires_at")
  @@map("auth_tokens")
}

model Workspace {
  id                String            @id @default(cuid())
  name              String            @db.VarChar(120)
  plan              WorkspacePlan     @default(FREE)
  storageLimitBytes BigInt            @default(2147483648) @db.UnsignedBigInt
  storageUsedBytes  BigInt            @default(0) @db.UnsignedBigInt
  createdByUserId   String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdByUser     User              @relation("workspace_creator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  lastUsedByUsers   User[]            @relation("workspace_last_used_by_users")
  members           WorkspaceMember[]
  projects          Project[]

  @@index([createdByUserId], map: "idx_workspace_created_by")
  @@index([plan], map: "idx_workspace_plan")
  @@map("workspaces")
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  name        String        @db.VarChar(120)
  description String?       @db.VarChar(500)
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  favorites ProjectFavorite[]

  @@index([workspaceId], map: "idx_project_workspace")
  @@index([workspaceId, status], map: "idx_project_workspace_status")
  @@map("projects")
}

model ProjectFavorite {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId], map: "uk_project_favorite_project_user")
  @@index([userId], map: "idx_project_favorite_user")
  @@map("project_favorites")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId], map: "uk_workspace_member_workspace_user")
  @@index([userId], map: "idx_workspace_member_user")
  @@index([workspaceId, role], map: "idx_workspace_member_workspace_role")
  @@map("workspace_members")
}
