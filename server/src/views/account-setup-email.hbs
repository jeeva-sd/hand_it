<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            margin: 0;
            padding: 0;
            background: #f3f6fb;
            font-family: Arial, sans-serif;
            color: #1f2937;
        }
        .container {
            max-width: 620px;
            margin: 24px auto;
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #e5e7eb;
        }
        .content {
            padding: 28px;
        }
        .logo {
            width: 88px;
            height: auto;
            display: block;
            margin-bottom: 20px;
        }
        h1 {
            margin: 0 0 12px;
            font-size: 24px;
            line-height: 1.3;
            color: #111827;
        }
        p {
            margin: 0 0 14px;
            font-size: 15px;
            line-height: 1.6;
        }
        .button {
            display: inline-block;
            margin: 12px 0 10px;
            padding: 12px 18px;
            border-radius: 8px;
            background: #0f766e;
            color: #ffffff !important;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
        }
        .muted {
            color: #6b7280;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="content">
            <img src="{{logoUrl}}" alt="Logo" class="logo" />
            <h1>Welcome to HandIt</h1>
            <p>Hello {{titleCase name}},</p>
            <p>Your account is ready. Click below to set your password and complete account setup.</p>
            <a href="{{resetLink}}" class="button">Set Password</a>
            <p class="muted">This link expires in {{expiresIn}}.</p>
        </div>
    </div>
</body>
</html>
