<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <style>
        :root {
            --bg: #f8faff;
            --card: #ffffff;
            --text: #0f172a;
            --muted: #475569;
            --accent: #2563eb;
            --accent-hover: #1d4ed8;
            --danger: #b42318;
            --ring: rgba(37, 99, 235, 0.22);
            --border: #dbe5ef;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Trebuchet MS", "Segoe UI", sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 18% 18%, rgba(37, 99, 235, 0.1), transparent 36%),
                radial-gradient(circle at 82% 0%, rgba(96, 165, 250, 0.12), transparent 30%),
                var(--bg);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .card {
            width: 100%;
            max-width: 460px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 18px 48px rgba(37, 99, 235, 0.14);
            padding: 28px;
        }

        h1 {
            margin: 0 0 8px;
            font-size: 28px;
            line-height: 1.2;
            letter-spacing: -0.02em;
        }

        .subtitle {
            margin: 0 0 20px;
            color: var(--muted);
            font-size: 15px;
            line-height: 1.5;
        }

        .field {
            margin-bottom: 14px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 6px;
            color: #334155;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        input {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 15px;
            padding: 12px 12px;
            outline: none;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px var(--ring);
        }

        button {
            width: 100%;
            border: 0;
            border-radius: 10px;
            background: var(--accent);
            color: #ffffff;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            padding: 12px 14px;
            transition: background-color 0.2s ease;
        }

        button:hover {
            background: var(--accent-hover);
        }

        button:disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }

        .note {
            margin-top: 16px;
            font-size: 13px;
            color: var(--muted);
            line-height: 1.5;
        }

        .error {
            margin-top: 14px;
            border-radius: 10px;
            background: #fef3f2;
            border: 1px solid #fecdca;
            color: var(--danger);
            padding: 10px 12px;
            font-size: 14px;
        }

        .success {
            margin-top: 14px;
            border-radius: 10px;
            background: #ecfdf3;
            border: 1px solid #abefc6;
            color: #067647;
            padding: 10px 12px;
            font-size: 14px;
        }

        @media (max-width: 480px) {
            .card {
                padding: 22px;
            }

            h1 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <main class="card">
        <h1>{{title}}</h1>
        <p class="subtitle">{{subtitle}}</p>

        {{#if valid}}
            <form id="reset-form" novalidate data-submit-endpoint="{{submitEndpoint}}" data-token="{{token}}">
                <div class="field">
                    <label for="password">New Password</label>
                    <input
                        id="password"
                        name="password"
                        type="password"
                        minlength="8"
                        maxlength="128"
                        autocomplete="new-password"
                        required
                    />
                </div>
                <div class="field">
                    <label for="confirmPassword">Confirm Password</label>
                    <input
                        id="confirmPassword"
                        name="confirmPassword"
                        type="password"
                        minlength="8"
                        maxlength="128"
                        autocomplete="new-password"
                        required
                    />
                </div>
                <button id="submit-button" type="submit">Save Password</button>
                <p class="note">Password must include uppercase, lowercase, and number.</p>
            </form>
            <div id="error-box" class="error" style="display: none"></div>
            <div id="success-box" class="success" style="display: none"></div>
            <noscript>
                <div class="error">This page requires JavaScript to securely update your password.</div>
            </noscript>
            <script src="/static/auth/reset-password.js" defer></script>
        {{else}}
            <div class="error">{{invalidReason}}</div>
        {{/if}}
    </main>
</body>
</html>
