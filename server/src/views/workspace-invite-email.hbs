<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Workspace Invitation</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: #f8fafc;
            font-family: "Segoe UI", Arial, sans-serif;
            color: #0f172a;
        }
        .container {
            max-width: 620px;
            margin: 24px auto;
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
        }
        .content {
            padding: 32px;
        }
        .brand {
            margin: 0 0 14px;
            color: #2563eb;
            font-size: 20px;
            font-weight: 800;
            letter-spacing: 0.01em;
        }
        h1 {
            margin: 0 0 12px;
            font-size: 24px;
            line-height: 1.3;
            color: #0f172a;
        }
        p {
            margin: 0 0 14px;
            font-size: 15px;
            line-height: 1.6;
            color: #334155;
        }
        .button {
            display: inline-block;
            margin: 12px 0 10px;
            padding: 12px 18px;
            border-radius: 8px;
            background: #2563eb;
            color: #ffffff !important;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
        }
        .link {
            color: #2563eb;
            word-break: break-all;
            text-decoration: none;
        }
        .muted {
            color: #64748b;
            font-size: 13px;
        }
        .footer {
            margin-top: 22px;
            padding-top: 16px;
            border-top: 1px solid #e2e8f0;
            color: #64748b;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="content">
            <p class="brand">Handit</p>
            <h1>You've been invited!</h1>
            <p>Hello,</p>
            <p><strong>{{inviterName}}</strong> has invited you to join the <strong>{{workspaceName}}</strong> workspace on Handit.</p>
            
            {{#if isNewUser}}
                <p>Since you don't have an account yet, please set up your account first:</p>
                <a href="{{setupLink}}" class="button">Set Up Account</a>
                <p class="muted">After setting up your account, you can accept the invitation.</p>
            {{else}}
                <a href="{{inviteLink}}" class="button">View Invitation</a>
            {{/if}}
            
            <p class="muted">If the button does not work, use this link:</p>
            <p><a class="link" href="{{#if isNewUser}}{{setupLink}}{{else}}{{inviteLink}}{{/if}}">{{#if isNewUser}}{{setupLink}}{{else}}{{inviteLink}}{{/if}}</a></p>
            <p class="footer">Handit Team</p>
        </div>
    </div>
</body>
</html>
