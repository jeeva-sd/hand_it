{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "baseUrl": "./src",
        "paths": {
            "~/*": ["./*"],
            "src/*": ["*"]
        },
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "strict": true,
        "strictNullChecks": true,
        "noImplicitAny": true
    },
    "ts-node": {
        "require": ["tsconfig-paths/register"],
        "transpileOnly": true,
        "esm": false
    }
}
